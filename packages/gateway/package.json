{
  "name": "gateway",
  "version": "1.0.0",
  "description": "GraphQL gateway aggregating REST microservices via Apollo Server 4",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@apollo/datasource-rest": "^6.3.0",
    "@apollo/server": "^4.10.4",
    "@apollo/utils.keyvadapter": "^3.1.0",
    "@as-integrations/express4": "^1.0.0",
    "@gas/shared": "workspace:*",
    "@graphql-tools/merge": "^9.0.4",
    "@graphql-tools/utils": "^10.3.1",
    "@keyv/redis": "^4.2.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dataloader": "^2.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "keyv": "^5.2.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
