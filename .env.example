# ─────────────────────────────────────────────
# Gateway
# ─────────────────────────────────────────────
GATEWAY_PORT=4000
NODE_ENV=development

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Microservice URLs
USER_SERVICE_URL=http://localhost:3001
ORDER_SERVICE_URL=http://localhost:3002
PRODUCT_SERVICE_URL=http://localhost:3003

# Redis
REDIS_URL=redis://localhost:6379

# Cache TTLs (seconds)
CACHE_TTL_USER=60
CACHE_TTL_ORDER=30
CACHE_TTL_PRODUCT=120

# ─────────────────────────────────────────────
# User Service
# ─────────────────────────────────────────────
USER_SERVICE_PORT=3001
USER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/user_db?schema=public

# ─────────────────────────────────────────────
# Order Service
# ─────────────────────────────────────────────
ORDER_SERVICE_PORT=3002
ORDER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_db?schema=public

# ─────────────────────────────────────────────
# Product Service
# ─────────────────────────────────────────────
PRODUCT_SERVICE_PORT=3003
PRODUCT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_db?schema=public

# ─────────────────────────────────────────────
# PostgreSQL (Docker)
# ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
